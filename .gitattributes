# Force LF line endings for shell scripts and text files on all platforms
* text=auto

*.sh        text eol=lf
*.service   text eol=lf
*.desktop   text eol=lf
*.py        text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.txt       text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
